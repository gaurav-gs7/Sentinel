apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization
namespace: {{ .Service.Namespace }}
resources:
  - ../../base
labels:
  - pairs:
      sentinel.dev/environment: prod
    includeSelectors: true
    includeTemplates: true
patches:
  - target:
      kind: HorizontalPodAutoscaler
      name: {{ .Service.Name }}
    patch: |-
      - op: replace
        path: /spec/maxReplicas
        value: 10
